{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "ws"],
    "typeRoots": ["../../crates/ts-wasm/node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@zerodds/wasm": ["../../crates/ts-wasm/dist/index.d.ts"],
      "ws": ["../../crates/ts-wasm/node_modules/@types/ws/index.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
