// SPDX-License-Identifier: Apache-2.0
// Canonical keyed types for cross-vendor KeyHash (PID_KEY_HASH, 0x0070)
// conformance. See README.md for the <=16-byte-vs-MD5 rule (DDSI-RTPS 2.5
// §9.6.3.8 / OMG XTypes 1.3 §7.6.8).
//
// Each type is registered as its own topic. The KeyHash of one fixed
// instance per type is computed by ZeroDDS and compared byte-for-byte
// against CycloneDDS / RTI Connext / Fast DDS.
//
// Case (d) (nested @key struct) is generated below: the ZeroDDS Rust backend
// now expands a nested-struct @key member into the nested struct's own @key
// members in member-id order (XTypes 1.3 §7.6.8 step 3), matching CycloneDDS /
// RTI / FastDDS. The keyholder it emits is byte-identical to the hand-built
// PlainCdr2BeKeyHolder previously used to prove this case.

module keyhash {

  // ---- Case (a): single @key long  ->  4-byte keyholder  ->  zero-pad ----
  @final
  struct SingleKey {
    @key long id;
    long       payload;
  };

  // ---- Case (b): @key string (unbounded) + @key long, serialized > 16B ->
  //               MD5 path. The unbounded string forces the MD5 branch.
  @final
  struct BigKey {
    @key string name;
    @key long   region;
    long        payload;
  };

  // ---- Case (c): multiple @key fields of mixed primitive types.
  //               octet(1) + pad(1) + short(2) + long(4) + char(1) = 9 bytes
  //               max <= 16 -> zero-pad.
  @final
  struct MixedKeys {
    @key octet  a;
    @key short  b;
    @key long   c;
    @key char   d;
    long        payload;
  };

  // ---- Case (d): nested @key struct. The OuterKey's @key member is itself
  //               a struct whose hi/lo are both @key; the keyholder expands
  //               to BE(hi) + BE(lo) = 8 bytes, max <= 16 -> zero-pad.
  //               (XTypes 1.3 §7.6.8 step 3 — recursive key expansion.)
  @nested @final
  struct NestedKey {
    @key long hi;
    @key long lo;
  };

  @final
  struct OuterKey {
    @key NestedKey k;
    long           payload;
  };

};
