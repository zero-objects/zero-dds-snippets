// Top-level combined conformance type (union + optional excluded — runtime blockers).
enum Mode { MODE_IDLE, MODE_ACTIVE, MODE_FAULT };

typedef double CurrentInAmpsType;

struct Sample {
  long  seq;
  double value;
};

@appendable
struct Telemetry {
  @key long              unitId;
  @key string            region;
  Mode                   mode;
  CurrentInAmpsType      batteryCurrent;
  sequence<Sample>       history;
  map<string, long>      counters;
  long                   window[4];
};
