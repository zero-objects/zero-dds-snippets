// Combined-feature conformance type for the ZeroDDS C# (XCDR2) binding.
//
// This is the LARGEST feature combination that the C# stack ROUND-TRIPS
// end-to-end over a real DCPS loopback. After the 2026-06 codegen/runtime fix
// pass (ref-struct reader passed by ref, map/union/fixed-array/typedef-to-
// primitive/nested-seq codecs), the previously-blocked aggregate features are
// now back in this one @key'd topic:
//
//   * enum member
//   * nested struct member        (Position location)
//   * sequence<struct>            (sequence<Sample> history)
//   * bounded string<32>
//   * bounded   sequence<long, N>
//   * unbounded sequence<long>
//   * sequence<string>
//   * nested sequence<sequence<long>>
//   * map<string, long>
//   * union member (switch on enum) + standalone union topic-capable codec
//   * fixed array  long window[4]
//   * typedef-to-primitive member (CurrentInAmps battery)
//   * @optional double  (exercised both present and absent)
//   * two @key members (long + bounded string)
module confcombo {

  enum Mode { MODE_IDLE, MODE_ACTIVE, MODE_FAULT };

  typedef double CurrentInAmps;

  struct Position {
    double x;
    double y;
    double z;
  };

  struct Sample {
    long   seq;
    double value;
  };

  union Reading switch (Mode) {
    case MODE_IDLE:   long       idleTicks;
    case MODE_ACTIVE: double     activeRate;
    default:          string<16> faultCode;
  };

  @appendable
  struct Telemetry {
    @key long                       unitId;
    @key string<32>                 region;
    Mode                            mode;
    double                          batteryVolts;
    CurrentInAmps                   batteryCurrent;
    Position                        location;
    sequence<Sample>                history;
    sequence<long>                  samples;
    sequence<long, 8>               recentCodes;
    sequence<string>                tags;
    sequence<sequence<long> >       matrix;
    map<string, long>               counters;
    Reading                         reading;
    long                            window[4];
    @optional double                calibration;
  };
};
