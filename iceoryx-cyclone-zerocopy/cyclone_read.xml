<?xml version="1.0" encoding="UTF-8"?>
<!-- Cyclone config for the READ direction (Cyclone publishes over iceoryx, the
     ZeroDDS reader consumes). INSTANCE_NAME is the iceoryx service string.
     Do NOT use the legacy <SharedMemory><Enable> element — it spawns a shadow
     default PSMX that overrides this config attribute. -->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General><Interfaces>
      <PubSubMessageExchange type="iox" library="/opt/cyclone/lib/libpsmx_iox.so" config="INSTANCE_NAME=DDS_CYCLONE;LOG_LEVEL=INFO;" />
    </Interfaces></General>
  </Domain>
</CycloneDDS>
